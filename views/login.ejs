<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>TrackDoc – Document Activity Intelligence</title>
    <link rel="stylesheet" href="/css/login.css">
</head>

<body>

<div class="background"></div>

<div class="hero-container">

    <div class="hero-left">
        <h1 class="big-title">
            Track, Analyze & Understand<br>
            Your Document Activity
        </h1>

        <p class="subtitle">
            TrackDoc reveals hidden edit trails, timestamped changes,
            suspicious activity patterns, and behavior analytics using
            advanced document forensics.
        </p>

        <!-- Google OAuth CTA -->
        <a href="/auth/google" class="cta-button">
            <img src="/images/google-icon.png" class="google-icon" alt="Google">
            Continue with Google
        </a>

        <div class="feature-row">
            <div class="feature-box">✔ Version History Extraction</div>
            <div class="feature-box">✔ User Activity Timeline</div>
            <div class="feature-box">✔ Anomaly Detection</div>
            <div class="feature-box">✔ Forensic Export Reports</div>
        </div>
    </div>

    <div class="hero-right">
        <img
            src="/images/analytics-hero.png"
            class="hero-image"
            alt="Document activity analytics illustration"
        >
    </div>

</div>

<!-- Footer -->
<footer class="footer">
    <ul>
        <li><a href="/privacy-policy">Privacy Policy</a></li>
        <li><a href="/terms-of-service">Terms of Service</a></li>
    </ul>
</footer>

<!-- Scripts MUST be inside body -->
<script src="/js/theme.js"></script>

</body>
</html>
